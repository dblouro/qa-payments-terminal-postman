    {
      "name": "Start Payment (Confirmed)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verificar status HTTP 200\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Verificar que o JSON tem um campo \"json\" (pois httpbin responde dentro de \"json\")\r",
              "pm.test(\"Response has JSON body\", function () {\r",
              "    pm.expect(pm.response.json()).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "// Verificar que o amount está correto no request\r",
              "pm.test(\"Amount sent in request is 100.00 (sanity)\", function () {\r",
              "    var jsonData = pm.request.json();\r",
              "    pm.expect(jsonData.amount).to.eql(100.00);\r",
              "});\r",
              "\r",
              "// Simular que o backend devolveria status: approved etc.\r",
              "pm.test(\"Simulate: expected structure in response\", function () {\r",
              "    var responseBody = pm.response.json();\r",
              "\r",
              "    // Em httpbin, o body original é devolvido dentro de \"json\"\r",
              "    pm.expect(responseBody).to.have.property(\"json\");\r",
              "    pm.expect(responseBody.json).to.have.property(\"amount\");\r",
              "    pm.expect(responseBody.json).to.have.property(\"currency\");\r",
              "    pm.expect(responseBody.json.currency).to.eql(\"EUR\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
