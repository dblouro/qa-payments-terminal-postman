    {
      "name": "Check Payment Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verificar status HTTP 200\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Verificar que o parâmetro id foi enviado na query\r",
              "pm.test(\"URL query parameter 'id' is present\", function () {\r",
              "    pm.expect(pm.request.url.query).to.have.property(\"id\");\r",
              "    pm.expect(pm.request.url.query.id).to.have.property(\"value\", \"TX123456789\");\r",
              "});\r",
              "\r",
              "// Verificar que a resposta ecoa o parâmetro (mock)\r",
              "pm.test(\"Response contains the id in query parameters\", function () {\r",
              "    var responseBody = pm.response.json();\r",
              "    pm.expect(responseBody).to.have.property(\"args\");\r",
              "    pm.expect(responseBody.args).to.have.property(\"id\");\r",
              "    pm.expect(responseBody.args.id).to.eql(\"TX123456789\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
